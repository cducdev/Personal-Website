---
import PostEditor from '../../../components/PostEditor.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { applyWriteAccessToPage } from '../../../lib/write-access';

const access = applyWriteAccessToPage(Astro);
---

<BaseLayout title="New Post" description="Private page for writing a new blog post." lang="en">
	{
		access.authorized ? (
			<section class="write-page">
				<header class="panel write-intro">
					<p class="eyebrow">4uckd3v@profile:~/admin/posts/new</p>
					<h1 class="blog-title">New Post</h1>
					<p class="hero-copy">
						Write a new post here, then manage its status later from the post list or edit page.
					</p>
					<a class="back-link" href="/admin/posts/">Back to all posts</a>
				</header>

				<PostEditor mode="new" />
			</section>
		) : (
			<section class="panel section-card">
				<p class="section-label">locked</p>
				<h1 class="article-title">Authentication required</h1>
				<p class="about-copy">{access.message}</p>
			</section>
		)
	}
</BaseLayout>
