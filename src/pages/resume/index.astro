---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Resume"
	description="Printable resume page for Duc Dev."
	lang="en"
>
	<section class="resume-page panel">
		<p class="eyebrow">4uckd3v@profile:~/resume</p>
		<h1 class="resume-title">Duc Dev</h1>
		<p class="resume-subtitle">
			Student in the specialized Informatics class at Nguyen Khiem High School for the Gifted, Da Nang,
			with experience in web development, generative AI, and web pentesting.
		</p>

		<div class="resume-grid">
			<section class="resume-section">
				<h2>Profile</h2>
				<p>
					I am building my technical foundation through practical projects and consistent
					note-taking. My current background combines web development, generative AI work
					such as RAG and multi-agent systems, and hands-on web pentesting.
				</p>
			</section>

			<section class="resume-section">
				<h2>Experience Areas</h2>
				<ul>
					<li>Web development across interfaces and application flows</li>
					<li>Generative AI systems, especially RAG and multi-agent approaches</li>
					<li>Web pentesting with an emphasis on practical attacker thinking</li>
					<li>Structured technical note-taking and technical blogging</li>
				</ul>
			</section>

			<section class="resume-section">
				<h2>Working Style</h2>
				<ul>
					<li>Prefer hands-on building and testing over theory-only learning</li>
					<li>Turn experiments and findings into notes that stay searchable</li>
					<li>Value calm workflows, clear systems, and repeatable practice</li>
				</ul>
			</section>

			<section class="resume-section">
				<h2>Links</h2>
				<ul>
					<li>Website: ducdev.io.vn</li>
					<li>Blog: ducdev.io.vn/blog/</li>
					<li>Printable PDF: ducdev.io.vn/resume.pdf</li>
				</ul>
			</section>
		</div>
	</section>
</BaseLayout>
